# Copy this file to .env for local development.
# For SQLite development, this creates dev.db in the project root.
DATABASE_URL=sqlite:///./dev.db

# For PostgreSQL, use this shape:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DB_NAME?sslmode=require

APP_NAME=AlumnixHub
SECRET_KEY=change-me-for-production
APP_BASE_URL=http://127.0.0.1:8000

EMAIL_ENABLED=false
SMTP_TLS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_NAME=AlumnixHub
EMAIL_FROM_EMAIL=

IOT_API_KEY=change-me-for-iot-demo
